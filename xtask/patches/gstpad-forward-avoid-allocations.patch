+/* We stack-allocate for N_STACK_ALLOCATE_FORWARDED_PADS pads as a first step.
+ * If more are needed, we will re-allocate with g_malloc(). This should usually
+ * never be needed */
+#define N_STACK_ALLOCATE_FORWARDED_PADS (16)
+
+/* The pad pointers are only ever compared, not dereferenced, mirroring what
+ * the pointer-keyed hash table previously used here did */
+static gboolean
+gst_pad_forward_already_pushed (GstPad ** pads, guint n_pads, GstPad * pad)
+{
+  guint i;
+
+  for (i = 0; i < n_pads; i++) {
+    if (pads[i] == pad)
+      return TRUE;
+  }
+  return FALSE;
+}
+
+/* Fast path of gst_pad_forward() for pads using the default internal-links
+ * function: walk the parent element's opposite-direction pad list directly
+ * instead of allocating a GstIterator. This takes the same object lock and
+ * checks the same pads_cookie the iterator would use, so the iteration and
+ * resync semantics are identical. */
+static gboolean
+gst_pad_forward_default_links (GstPad * pad, GstElement * eparent,
+    GstPadForwardFunction forward, gpointer user_data)
+{
+  gboolean result = FALSE;
+  GstPad *pushed_pads_stack[N_STACK_ALLOCATE_FORWARDED_PADS];
+  GstPad **pushed_pads = pushed_pads_stack;
+  guint n_pushed_pads = 0;
+  guint pushed_pads_size = N_STACK_ALLOCATE_FORWARDED_PADS;
+  gboolean resynced = FALSE;
+  GList **padlist;
+  guint32 cookie;
+  GList *l;
+
+  if (pad->direction == GST_PAD_SRC)
+    padlist = &eparent->sinkpads;
+  else
+    padlist = &eparent->srcpads;
+
+  GST_OBJECT_LOCK (eparent);
+
+restart:
+  cookie = eparent->pads_cookie;
+
+  for (l = *padlist; l != NULL; l = l->next) {
+    GstPad *intpad = GST_PAD_CAST (l->data);
+
+    /* if we have restarted, check if we have already pushed */
+    if (resynced
+        && gst_pad_forward_already_pushed (pushed_pads, n_pushed_pads, intpad))
+      continue;
+
+    /* the list holds a ref, but the pad must stay alive while we drop the
+     * lock to call the forward function */
+    gst_object_ref (intpad);
+    GST_OBJECT_UNLOCK (eparent);
+
+    GST_LOG_OBJECT (pad, "calling forward function on pad %s:%s",
+        GST_DEBUG_PAD_NAME (intpad));
+    result = forward (intpad, user_data);
+
+    GST_OBJECT_LOCK (eparent);
+
+    /* reallocate on the heap if we needed more than
+     * N_STACK_ALLOCATE_FORWARDED_PADS pads */
+    if (n_pushed_pads == pushed_pads_size) {
+      pushed_pads_size *= 2;
+      if (pushed_pads == pushed_pads_stack) {
+        pushed_pads = g_new (GstPad *, pushed_pads_size);
+        memcpy (pushed_pads, pushed_pads_stack, sizeof (pushed_pads_stack));
+      } else {
+        pushed_pads = g_renew (GstPad *, pushed_pads, pushed_pads_size);
+      }
+    }
+    pushed_pads[n_pushed_pads++] = intpad;
+    gst_object_unref (intpad);
+
+    if (result)
+      break;
+
+    /* the lock was released while calling the forward function, the pad
+     * list might have changed */
+    if (G_UNLIKELY (cookie != eparent->pads_cookie)) {
+      resynced = TRUE;
+      goto restart;
+    }
+  }
+
+  GST_OBJECT_UNLOCK (eparent);
+
+  if (pushed_pads != pushed_pads_stack)
+    g_free (pushed_pads);
+
+  return result;
+}
