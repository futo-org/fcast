+/* Build and attach the structure for event types that carry their
+ * payload inline. May be called on a non-writable event from multiple
+ * threads; the first materialized structure wins. */
+static GstStructure *
+gst_event_materialize_structure (GstEvent * event)
+{
+  GstEventImpl *impl = (GstEventImpl *) event;
+  GstStructure *structure;
+
+  switch (GST_EVENT_TYPE (event)) {
+    case GST_EVENT_QOS:
+      structure = gst_structure_new_static_str ("GstEventQOS",
+          "type", GST_TYPE_QOS_TYPE, impl->payload.qos.type,
+          "proportion", G_TYPE_DOUBLE, impl->payload.qos.proportion,
+          "diff", G_TYPE_INT64, impl->payload.qos.diff,
+          "timestamp", G_TYPE_UINT64, impl->payload.qos.timestamp, NULL);
+      break;
+    default:
+      return NULL;
+  }
+
+  gst_structure_set_parent_refcount (structure, &event->mini_object.refcount);
+
+  if (!g_atomic_pointer_compare_and_exchange (&impl->structure, NULL,
+          structure)) {
+    /* lost the race, another thread attached a structure first */
+    gst_structure_set_parent_refcount (structure, NULL);
+    gst_structure_free (structure);
+    structure = g_atomic_pointer_get (&impl->structure);
+  }
+
+  return structure;
+}
+
 const GstStructure *
 gst_event_get_structure (GstEvent * event)
 {
+  GstStructure *structure;
+
   g_return_val_if_fail (GST_IS_EVENT (event), NULL);
 
-  return GST_EVENT_STRUCTURE (event);
+  structure = g_atomic_pointer_get (&((GstEventImpl *) event)->structure);
+  if (G_UNLIKELY (structure == NULL))
+    structure = gst_event_materialize_structure (event);
+
+  return structure;
 }
 
