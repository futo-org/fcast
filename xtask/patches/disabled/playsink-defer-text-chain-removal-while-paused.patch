   GST_DEBUG_OBJECT (playsink, "audio:%d, video:%d, vis:%d, text:%d", need_audio,
       need_video, need_vis, need_text);
 
+  /* Removing the text chain deactivates its pads, which takes their stream
+   * locks -- held by any in-flight push. Those pushes only complete when
+   * the sinks consume, i.e. in steady PLAYING: in any other state a buffer
+   * that already passed the ghost-pad blocks can sit forever in the video
+   * sink's preroll wait while still holding a text-chain pad lock, and the
+   * removal then deadlocks this reconfigure -- and with it every later
+   * playsink state change (they wait on reconfiguration_in_progress).
+   * Defer the removal, keeping the silenced chain linked in the video
+   * path; the PAUSED->PLAYING transition re-triggers a reconfigure that
+   * performs the real removal under flowing data. */
+  defer_text_removal = !need_text && playsink->textchain != NULL
+      && playsink->textchain->chain.added && playsink->text_pad == NULL
+      && !(GST_STATE (playsink) == GST_STATE_PLAYING
+      && GST_STATE_PENDING (playsink) == GST_STATE_VOID_PENDING);
+
   /* set up video pipeline */
   if (need_video) {
     gboolean raw, async;
