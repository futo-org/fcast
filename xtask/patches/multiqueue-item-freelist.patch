+/* Recycle pool for GstMultiQueueItem to avoid a malloc/free per queued
+ * object. Shared by all multiqueue instances and never freed; capped so
+ * at most ITEM_POOL_MAX_SIZE items are retained when idle. */
+#define ITEM_POOL_MAX_SIZE 256
+
+static GstAtomicQueue *item_pool;
+
+static GstMultiQueueItem *
+gst_multi_queue_item_alloc (void)
+{
+  static gsize init = 0;
+  GstMultiQueueItem *item;
+
+  if (g_once_init_enter (&init)) {
+    item_pool = gst_atomic_queue_new (16);
+    g_once_init_leave (&init, 1);
+  }
+
+  item = gst_atomic_queue_pop (item_pool);
+  if (item == NULL)
+    item = g_new (GstMultiQueueItem, 1);
+
+  return item;
+}
+
 static void
 gst_multi_queue_item_destroy (GstMultiQueueItem * item)
 {
   if (!item->is_query && item->object)
     gst_mini_object_unref (item->object);
-  g_free (item);
+  /* the pool always exists here, items are only created through
+   * gst_multi_queue_item_alloc() */
+  if (gst_atomic_queue_length (item_pool) < ITEM_POOL_MAX_SIZE)
+    gst_atomic_queue_push (item_pool, item);
+  else
+    g_free (item);
 }
 
 /* takes ownership of passed mini object! */
