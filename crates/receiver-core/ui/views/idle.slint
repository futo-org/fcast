import {
    Icons,
    FText,
    Button,
} from "../../../../senders/ui-components/std-widgets.slint";
import {
    FCastPalette,
} from "../../../../senders/ui-components/styling.slint";
import { Bridge, UiUpdaterState } from "../globals.slint";

component ReceiverInfoEntry inherits HorizontalLayout {
    in property <image> icon <=> i-icon.source;
    in property <length> icon-width <=> i-icon.width;
    in property <length> icon-height <=> i-icon.height;
    in property <string> key;
    in property <string> value;

    padding: 5px;
    spacing: 15px;

    VerticalLayout {
        alignment: center;

        i-icon := Image { }
    }

    VerticalLayout {
        Text {
            text: key;
            color: FCastPalette.opacity-light-700;
            font-size: 12px;
        }

        Text {
            text: value;
            color: FCastPalette.foreground;
            font-size: 14px;
            wrap: word-wrap;
        }
    }

    Rectangle { }
}

component IdleText inherits FText {
    color: @linear-gradient(180deg, #FFFFFF 17.11%, #B4B4B4 78.95%);
    wrap: word-wrap;
}

export component IdleView inherits Rectangle {
    Image {
        source: Icons.background-dark;
        width: 100%;
        height: 100%;
    }

    VerticalLayout {
        padding: 32px;
        padding-right: 58px;
        padding-left: self.padding-right;
        spacing: 20px;


        // TODO: re-introduce when we have settings
        // HorizontalLayout {
        //     Rectangle { }

        //     Button {
        //         icon-size: 18px;
        //         width: 40px;
        //         height: 40px;
        //         background-default-color: @linear-gradient(133.14deg, rgba(52, 52, 52, 0.1) 6.7%, rgba(20, 20, 20, 0.1) 92.77%);
        //         icon: Icons.settings;
        //     }
        // }

        HorizontalLayout {
            alignment: space-between;

            Rectangle {
                max-width: 500px;

                VerticalLayout {
                    padding: 10px;
                    spacing: 10px;
                    visible: !Bridge.is-playing();
                    alignment: center;

                    IdleText {
                        font-size: 28px;
                        text: @tr("Idle. Ready to cast");
                        font-weight: 600;
                        font-family: "Outfit Semibold";
                        overflow: elide;
                        // color: @linear-gradient(180deg, #FFFFFF 17.11%, #B4B4B4 78.95%);
                    }

                    Text {
                        font-size: 12pt;
                        text: @tr("Stream to this device by opening your FCast sender app and selecting this device from the Cast menu, or scan the QR code for instant setup.");
                        wrap: word-wrap;
                        overflow: elide;
                        color: FCastPalette.opacity-light-500;
                    }

                    Rectangle {
                        background: @linear-gradient(222.86deg, #262626 7.47%, #0E0F10 95.53%);
                        border-radius: 8px;
                        border-width: 1px;
                        border-color: @linear-gradient(180deg, rgba(255, 255, 255, 0.04) 0%, rgba(255, 255, 255, 0) 100%);

                        VerticalLayout {
                            padding: 10px;
                            spacing: 3px;

                            ReceiverInfoEntry {
                                icon: Icons.tv-outline;
                                icon-width: 15px;
                                icon-height: 12.3px;
                                key: @tr("Device name");
                                value: Bridge.device-name;
                            }

                            Rectangle {
                                height: 1px;
                                background: FCastPalette.opacity-light-1100;
                            }

                            ReceiverInfoEntry {
                                icon: Icons.network;
                                icon-width: 13.3px;
                                icon-height: 14px;
                                key: @tr("Local IP Address");
                                value: Bridge.local-ip-addrs;
                            }
                        }
                    }

                    if Bridge.updater-state == UiUpdaterState.ShowingDialog: VerticalLayout {
                        IdleText {
                            text: @tr("An update is available. Do you want to update now?");
                        }

                        HorizontalLayout {
                            padding-top: 5px;
                            spacing: 5px;

                            Button {
                                text: @tr("Yes");

                                clicked => Bridge.perform-app-update();
                            }

                            Button {
                                text: @tr("No");

                                clicked => {
                                    Bridge.updater-state = UiUpdaterState.None;
                                }
                            }
                        }
                    }

                    if Bridge.updater-state == UiUpdaterState.Downloading: VerticalLayout {
                        IdleText {
                            text: @tr("Downloading update...");
                        }

                        IdleText {
                            horizontal-alignment: center;
                            text: Bridge.update-download-progress + "%";
                        }
                    }

                    if Bridge.updater-state == UiUpdaterState.DownloadFailed: VerticalLayout {
                        IdleText {
                            text: @tr("Failed to download update: {}", Bridge.updater-error-msg);
                        }
                    }

                    if Bridge.updater-state == UiUpdaterState.InstallFailed: VerticalLayout {
                        IdleText {
                            text: @tr("Failed to install update: {}", Bridge.updater-error-msg);
                        }
                    }

                    if Bridge.updater-state == UiUpdaterState.InstallSuccessful: VerticalLayout {
                        IdleText {
                            text: @tr("Installed update successfully. Do you want to restart the app now?");
                        }

                        HorizontalLayout {
                            padding-top: 5px;
                            spacing: 5px;
                            Button {
                                text: @tr("Yes");

                                clicked => Bridge.restart-app();
                            }

                            Button {
                                text: @tr("No");

                                clicked => {
                                    Bridge.updater-state = UiUpdaterState.None;
                                }
                            }
                        }
                    }
                }
            }

            VerticalLayout{
                alignment: center;

                Rectangle {
                    width: 350px;
                    height: self.width;
                    border-radius: 8px;
                    clip: true;
                    background: Bridge.qr-code.width > 0 ? white : @linear-gradient(222.86deg, #262626 7.47%, #0E0F10 95.53%);

                    if Bridge.qr-code.width > 0: Image {
                        width: parent.width - 20px;
                        height: parent.height - 20px;
                        source <=> Bridge.qr-code;
                        image-rendering: pixelated;
                    }

                    if Bridge.qr-code.width == 0: VerticalLayout {
                        alignment: center;
                        spacing: 20px;
                        padding: 15px;

                        Rectangle {
                            Image {
                                source: Icons.warning-triangle;
                                width: 80px;
                            }

                            Image {
                                source: Icons.exclamation-mark;
                                width: 60px;
                            }
                        }

                        FText {
                            text: @tr("Your device isn’t connected to a network. Connect to network via LAN or Wifi to continue.");
                            wrap: word-wrap;
                            horizontal-alignment: center;
                            font-size: 18px;
                        }
                    }
                }
            }
        }
    }
}
