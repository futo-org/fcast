import {
    Icons,
    FText,
    ScrollView,
    Button,
    ListView,
} from "../../../../ui-components/std-widgets.slint";
import {
    Bridge,
    UiMediaTrack,
    GuiPlaybackState,
    UiMediaTrackType,
    UiMode,
} from "../globals.slint";
import {
    PositionScrubber,
    ProgressLabels,
    MasterButton,
    ScrubbyMcScrub,
    VolumePreview,
} from "../common.slint";
import {
    FCastPalette,
} from "../../../../ui-components/styling.slint";

component SecondaryButton inherits Button {
    icon-size: 18px;
    width: 45px;
    height: 45px;
    background-default-color: @linear-gradient(133.14deg, rgba(204, 204, 204, 0.1) 6.7%, rgba(122, 122, 122, 0.1) 92.77%);
    colorize-icon: true;
}

component PlaybackSettingsMenuItem inherits Rectangle {
    in property <string> label;
    in property <image> icon;

    callback clicked;

    border-radius: 6px;

    states [
        hover when i-ta.has-hover: {
            text.color: FCastPalette.foreground;
            arrow-icon.colorize: FCastPalette.foreground;
            background: FCastPalette.brand-600;
        }
    ]

    i-ta := TouchArea {
        clicked => root.clicked();
        mouse-cursor: pointer;
    }

    HorizontalLayout {
        padding: 8px;
        padding-top: 14px;
        padding-bottom: 14px;
        spacing: 8px;

        VerticalLayout {
            alignment: center;

            Image {
                width: 16px;
                height: 16px;
                source: icon;
            }
        }

        text := FText {
            text: label;
            color: FCastPalette.neutral-500;
        }

        Rectangle { }

        VerticalLayout {
            alignment: center;

            arrow-icon := Image {
                width: 4.67px;
                height: 8px;
                source: Icons.arrow-right;
            }
        }
    }
}

component SettingItem inherits Rectangle {
    in property <string> value;
    in property <bool> selected;

    callback clicked;

    border-radius: 6px;

    states [
        selected when selected: {
            background: @linear-gradient(90.92deg, #2D7AF8 0.79%, #0757D9 104.49%);
            icon.source: Icons.check-tick;
        }
        hover when ta.has-hover: {
            background: @linear-gradient(90.92deg, #2D7AF850 0.79%, #0757D950 104.49%);
        }
    ]

    ta := TouchArea {
        mouse-cursor: pointer;

        clicked => clicked();
    }

    HorizontalLayout {
        padding: 10px;
        padding-left: 12px;
        padding-right: 12px;
        spacing: 8px;

        FText {
            horizontal-stretch: 1;
            text: value;
            overflow: elide;
        }

        VerticalLayout {
            alignment: center;

            icon := Image {
                source: Icons.arrow-right;
            }
        }
    }
}

component PlaybackSettingHeader inherits HorizontalLayout {
    in property <string> title;

    callback navigate-previous;

    spacing: 15px;

    Button {
        icon: Icons.arrow-right;
        icon-size: 8px;
        width: 30px;
        height: 30px;
        transform-rotation: 180deg;
        colorize-icon: true;

        clicked => navigate-previous();
    }

    FText {
        text: title;
        font-weight: 500;
        font-size: 18px;
        vertical-alignment: center;
    }
}

component SettingsTrackList inherits Rectangle {
    in property <[UiMediaTrack]> tracks;
    in property <int> selected-id;
    in property <bool> can-be-disabled: false;

    callback clicked(id: int);

    ScrollView {
        viewport-height: vl.preferred-height;

        vl := VerticalLayout {
            if can-be-disabled: SettingItem {
                value: @tr("Off");
                selected: selected-id == -1;

                clicked => clicked(-1);
            }

            Rectangle {
                height: 1px;
                background: #FFFFFF0A;
            }

            for track in tracks: VerticalLayout {
                SettingItem {
                    value: track.name;
                    selected: selected-id == track.id;

                    clicked => clicked(track.id);
                }

                Rectangle {
                    height: 1px;
                    background: #FFFFFF0A;
                }
            }
        }
    }
}

component ButtonControls inherits Rectangle {
    callback show-settings();

    HorizontalLayout {
        alignment: space-between;

        Rectangle {
            width: right-side-ctrls.preferred-width;
        }

        Rectangle {
            MasterButton {
                height: 50px;
                width: 50px;
            }
        }

        right-side-ctrls := HorizontalLayout {
            alignment: end;
            spacing: 15px;

            settings-btn := SecondaryButton {
                icon: Icons.settings;
                clicked => show-settings();
            }
        }
    }
}

enum SettingsPage {
    Start,
    Video,
    Audio,
    Subtitle,
    Rate,
}

component PlaybackControls inherits Rectangle {
    out property <MouseCursor> suggested-cursor: default;
    // Driven by the parent: true while the pointer is anywhere inside the window.
    in property <bool> pointer-inside-window: true;

    property <bool> is-changing-volume: false;
    property <float> background-height: 100%;
    property <float> elems-opacity: 0%;
    property <bool> is-visible: false;
    property <bool> show-settings: false;
    property <SettingsPage> current-settings-page: SettingsPage.Start;

    forward-focus: focus;

    // True while any part of the controls is drawn over the video. Mirrored into the
    // Bridge so the video sink knows when its subsurface may sit above the GUI.
    property <bool> obstructing: is-visible
        || show-settings
        || elems-opacity > 0
        || background-height < 100%
        || settings-side-bar.width > 0px;

    changed obstructing => {
        Bridge.controls-overlay-visible = self.obstructing;
    }

    changed pointer-inside-window => {
        // Don't yank the controls away mid-scrub if the pointer slips out of the window while
        // dragging (mirrors the idle timer's guard).
        if !self.pointer-inside-window && !Bridge.is-scrubbing-position {
            close();
        }
    }

    init => {
        Bridge.controls-overlay-visible = self.obstructing;
    }

    animate elems-opacity, background-height {
        duration: 200ms;
        easing: ease-out-expo;
    }

    VerticalLayout {
        visible: background-height < 100%;

        Rectangle {
            background: @linear-gradient(0deg, rgba(0, 0, 0, 0.0), rgba(0, 0, 0, 0.8) 100%);
        }

        Rectangle {
            height: parent.height * background-height;
        }

        Rectangle {
            background: @linear-gradient(0deg, rgba(0, 0, 0, 1.0) 0%, rgba(0, 0, 0, 0.0) 100%);
        }
    }

    public function show() {
        tim.restart();
        if is-visible {
            return;
        }

        is-visible = true;
        background-height = 20%;
        elems-opacity = 100%;
        tim.running = true;
        suggested-cursor = MouseCursor.default;
    }

    public function close() {
        is-visible = false;
        background-height = 100%;
        elems-opacity = 0%;
        tim.running = false;
        suggested-cursor = MouseCursor.none;
    }

    // TODO: handle the case when focus leaves window
    ta := TouchArea {
        mouse-cursor: suggested-cursor;

        double-clicked => Bridge.toggle-fullscreen();

        clicked => {
            current-settings-page = SettingsPage.Start;
            show-settings = false;
        }

        pointer-event(pe) => {
            if (pe.kind == PointerEventKind.move) {
                parent.show();
            }
        }

        focus := FocusScope {
            capture-key-pressed(event) => Bridge.capture-key-pressed(event);

            focus-changed-event(event) => {
                if (event == FocusReason.window-activation && is-visible) {
                    root.close();
                }
            }

            init => self.focus();
        }
    }

    main-vlayout := VerticalLayout {
        padding: 58px;
        padding-top: 20px;
        padding-bottom: 20px;
        spacing: 5px;

        if Bridge.ui-mode == UiMode.Full: HorizontalLayout {
            visible: elems-opacity > 0;

            Rectangle { }

            SecondaryButton {
                opacity: elems-opacity;
                icon: Bridge.is-fullscreen ? Icons.minimize : Icons.maximize;

                clicked => Bridge.toggle-fullscreen();
            }
        }

        Rectangle { }

        ctrl-layout := Rectangle {
            height: self.preferred-height * elems-opacity;
            visible: is-visible;

            VerticalLayout {
                HorizontalLayout {
                    opacity: elems-opacity;
                    visible: is-visible;
                    padding: 10px;
                    padding-bottom: 15px;

                    FText {
                        text: Bridge.media-title;
                        width: 50%;
                        wrap: word-wrap;
                        overflow: elide;
                        font-size: 24px;
                        max-height: 5px;
                        font-weight: 500;
                        color: FCastPalette.neutral-100;
                    }

                    Rectangle { /* Spacer */ }

                    if Bridge.is-live: VerticalLayout {
                        opacity: elems-opacity;

                        Rectangle { }

                        Rectangle {
                            background: #FB2C2C;
                            border-radius: 3.3px;
                            width: i-hl.preferred-width;

                            i-hl := HorizontalLayout {
                                padding: 12px;
                                padding-top: 6px;
                                padding-bottom: self.padding-top;
                                spacing: 6px;

                                VerticalLayout {
                                    alignment: center;

                                    Rectangle {
                                        width: 8px;
                                        height: 8px;
                                        border-radius: 5px;
                                        background: FCastPalette.foreground;
                                    }
                                }

                                FText {
                                    text: @tr("LIVE");
                                    font-weight: 500;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }
                }

                ScrubbyMcScrub {
                    opacity: elems-opacity;
                    visible: is-visible;
                    height: is-visible ? self.preferred-height : 0px;
                }

                if Bridge.ui-mode == UiMode.Full: Rectangle {
                    height: 5px;
                }

                if Bridge.ui-mode == UiMode.Full: ButtonControls {
                    opacity: elems-opacity;
                    visible: is-visible;

                    show-settings => {
                        show-settings = true;
                    }
                }
            }
        }
    }

    HorizontalLayout {
        visible: settings-side-bar.width > 0px;

        Rectangle {}

        settings-side-bar := Rectangle {
            background: @linear-gradient(180deg, #101010 0%, #0F0F10 100%);
            border-color: @radial-gradient(circle, rgba(255, 255, 255, 0.04) 0%, rgba(102, 102, 102, 0.04) 100%);
            border-width: 1px;
            border-radius: 6px;
            width: show-settings ? root.width * 0.25 : 0px;
            animate width {
                duration: 100ms;
            }

            TouchArea {}

            if current-settings-page == SettingsPage.Start: VerticalLayout {
                padding: 15px;
                padding-top: 18px;

                FText {
                    text: @tr("Playback settings");
                    font-weight: 500;
                    font-size: 18px;
                }

                VerticalLayout {
                    padding-top: 10px;
                    spacing: 5px;

                    if Bridge.video-tracks.length > 0: PlaybackSettingsMenuItem {
                        label: @tr("Video");
                        icon: Icons.settings-video;

                        clicked => {
                            current-settings-page = SettingsPage.Video;
                        }
                    }

                    if Bridge.audio-tracks.length > 0: PlaybackSettingsMenuItem {
                        label: @tr("Audio");
                        icon: Icons.details-audio;

                        clicked => {
                            current-settings-page = SettingsPage.Audio;
                        }
                    }

                    if Bridge.subtitle-tracks.length > 0: PlaybackSettingsMenuItem {
                        label: @tr("Subtitles");
                        icon: Icons.subtitles;

                        clicked => {
                            current-settings-page = SettingsPage.Subtitle;
                        }
                    }

                    PlaybackSettingsMenuItem {
                        label: @tr("Playback Speed");
                        icon: Icons.playback-rate;

                        clicked => {
                            current-settings-page = SettingsPage.Rate;
                        }
                    }

                    Rectangle {}
                }
            }

            if current-settings-page == SettingsPage.Video: VerticalLayout {
                padding: 15px;
                padding-top: 18px;

                PlaybackSettingHeader {
                    title: @tr("Video track");

                    navigate-previous => {
                        current-settings-page = SettingsPage.Start;
                    }
                }

                VerticalLayout {
                    padding-top: 10px;
                    spacing: 5px;

                    // TODO: scroll view if needed
                    SettingsTrackList {
                        tracks: Bridge.video-tracks;
                        selected-id: Bridge.current-video-track;
                        clicked(id) => Bridge.select-track(id, UiMediaTrackType.Video);
                    }
                }
            }

            if current-settings-page == SettingsPage.Audio: VerticalLayout {
                padding: 15px;
                padding-top: 18px;

                PlaybackSettingHeader {
                    title: @tr("Audio track");

                    navigate-previous => {
                        current-settings-page = SettingsPage.Start;
                    }
                }

                VerticalLayout {
                    padding-top: 10px;
                    spacing: 5px;

                    // TODO: scroll view if needed
                    SettingsTrackList {
                        tracks: Bridge.audio-tracks;
                        selected-id: Bridge.current-audio-track;
                        clicked(id) => Bridge.select-track(id, UiMediaTrackType.Audio);
                    }
                }
            }

            if current-settings-page == SettingsPage.Subtitle: VerticalLayout {
                padding: 15px;
                padding-top: 18px;

                PlaybackSettingHeader {
                    title: @tr("Subtitle track");

                    navigate-previous => {
                        current-settings-page = SettingsPage.Start;
                    }
                }

                VerticalLayout {
                    padding-top: 10px;
                    spacing: 5px;

                    SettingsTrackList {
                        tracks: Bridge.subtitle-tracks;
                        selected-id: Bridge.current-subtitle-track;
                        can-be-disabled: true;
                        clicked(id) => {
                            Bridge.current-subtitle-track = id;
                            Bridge.select-track(id, UiMediaTrackType.Subtitle);
                        }
                    }
                }
            }

            if current-settings-page == SettingsPage.Rate: VerticalLayout {
                padding: 15px;
                padding-top: 18px;

                PlaybackSettingHeader {
                    title: @tr("Playback speed");

                    navigate-previous => {
                        current-settings-page = SettingsPage.Start;
                    }
                }

                VerticalLayout {
                    padding-top: 10px;
                    spacing: 5px;

                    property <[float]> rates: [0.25, 0.5, 0.75, 1.0, 1.25, 1.50, 1.75, 2.0];

                    ListView {
                        for rate in rates: VerticalLayout {
                            SettingItem {
                                value: rate;
                                selected: Bridge.playback-rate == rate;

                                clicked => {
                                    Bridge.change-playback-rate(rate);
                                    Bridge.playback-rate = rate;
                                }
                            }

                            Rectangle {
                                height: 1px;
                                background: #FFFFFF0A;
                            }
                        }
                    }
                }
            }
        }
    }

    tim := Timer {
        interval: 2s;
        running: true;
        triggered => {
            if !Bridge.is-scrubbing-position
                && (ta.has-hover || !focus.has-focus || show-settings) {
                parent.close();
                Bridge.hide-cursor-hack();
            }
        }
    }
}

export component VideoPlayerView inherits Rectangle {
    width: 100%;
    height: 100%;
    background: transparent;

    // Ancestor TouchArea covering the whole view: its has-hover stays true while the pointer is
    // anywhere in the window and drops to false the moment the pointer leaves the window. It
    // forwards events, so the controls underneath keep working. Feeds PlaybackControls so it can
    // hide the overlay on exit.
    window-hover := TouchArea {
        VolumePreview {
            width: 100%;
            height: 100%;
        }

        PlaybackControls {
            width: 100%;
            height: 100%;
            pointer-inside-window: window-hover.has-hover;
        }
    }
}
