import { ScrollView, Button } from "std-widgets.slint";
import {
    Bridge,
    AppState,
    UiPlayerVariant,
    UiVideoDbgInfo,
    UiBufferedRange,
} from "globals.slint";

// One axis-aligned box of the graph scene (element, bin or pad chrome).
export struct UiGraphRect {
    x: length,
    y: length,
    width: length,
    height: length,
    fill: color,
    stroke: color,
}

// A caps chip on a wire: `summary` is always visible. Hovering expands the
// chip in place to `detail-width`×`detail-height` showing `detail` (full
// caps, newline-separated), and highlights the wire (`edge`/`commands`).
export struct UiGraphLabel {
    x: length,
    y: length,
    width: length,
    height: length,
    summary: string,
    detail: string,
    detail-width: length,
    detail-height: length,
    edge: int,
    commands: string,
    arrow: string,
}

// A thin hover zone along one segment of a wire. Hovering it highlights
// that wire (drawing `commands`/`arrow` in the accent color).
export struct UiEdgeHit {
    x: length,
    y: length,
    width: length,
    height: length,
    edge: int,
    commands: string,
    arrow: string,
}

// A single left-aligned text label at (x, y) in the graph's coordinate space.
export struct UiGraphText {
    x: length,
    y: length,
    size: length,
    text: string,
    color: color,
}

export struct GraphDump {
    // Human-readable trigger for the dump (e.g. "Manual", "Error").
    trigger: string,
    // Wall-clock time the dump was taken.
    timestamp: string,
    // Scene bounds (receiver-side layout, logical pixels at zoom 1).
    width: length,
    height: length,
    rects: [UiGraphRect],
    // Caps chips: one compact line per wire, expanding to the full caps
    // block on hover.
    labels: [UiGraphLabel],
    // Per-segment hover zones for wire highlighting.
    hits: [UiEdgeHit],
    texts: [UiGraphText],
    // All edge polylines batched into one SVG path (right angles only), and
    // all arrowheads into another, so the whole wiring is two Path items.
    edges: string,
    arrows: string,
}

// One row of the track table (see `Application::inspector_track_row`).
export struct UiInspectorTrack {
    kind: string,
    codec: string,
    detail: string,
    language: string,
    selected: bool,
}

export global InspectorState {
    in-out property <bool> have-graph: false;
    in-out property <GraphDump> graph;
    // True while a fresh graph dump is being walked and laid out.
    in-out property <bool> dumping: false;

    // Per-tick player data (see `Application::inspector_tick`).
    in-out property <[UiInspectorTrack]> tracks;
    in-out property <string> container;
    in-out property <[string]> sources-lines;
    in-out property <[string]> internals-lines;
    in-out property <[string]> sink-lines;
    in-out property <string> image-info;

    // Bitrate sparklines for the selected video/audio streams. The receiver
    // renders each history into an SVG polyline over a fixed 300x100 viewbox
    // (newest sample at the right edge), so the UI just draws the strings.
    in-out property <bool> have-bitrate: false;
    in-out property <string> video-bitrate-path;
    in-out property <string> audio-bitrate-path;
    in-out property <string> video-bitrate-label;
    in-out property <string> audio-bitrate-label;
    in-out property <string> bitrate-peak-label;

    // Buffering health (see `Application::inspector_buffering`). STREAM mode
    // exposes a fill level + rates, not timeline ranges.
    in-out property <bool> have-buffering: false;
    in-out property <float> buffering-fill;
    in-out property <string> buffering-fill-label;
    in-out property <string> buffering-ahead-label;
    in-out property <string> buffering-mode-label;
    in-out property <string> buffering-eta-label;
}

component InfoRow inherits HorizontalLayout {
    in property <string> label;
    in property <string> value;

    spacing: 8px;

    Text {
        width: 96px;
        text: root.label;
        color: #8a8a8a;
        font-size: 12px;
        vertical-alignment: top;
    }

    // Never elide — the card sizes to fit the value, and a pathologically long
    // value wraps rather than getting cut off.
    Text {
        text: root.value == "" ? "-" : root.value;
        color: white;
        font-size: 12px;
        horizontal-stretch: 1;
        wrap: word-wrap;
    }
}

component VideoInfoCard inherits Rectangle {
    property <UiVideoDbgInfo> info: Bridge.video-dbg-info;

    min-width: 240px;
    max-width: 560px;
    background: #1c1c1eee;
    border-width: 1px;
    border-color: #ffffff20;

    VerticalLayout {
        padding: 12px;
        spacing: 5px;

        Text {
            text: "Video";
            color: white;
            font-size: 14px;
            font-weight: 700;
        }

        InfoRow {
            label: "Format";
            value: root.info.format;
        }

        InfoRow {
            label: "Resolution";
            value: root.info.resolution == ""
                ? Bridge.video-frame-width + "×" + Bridge.video-frame-height
                : root.info.resolution;
        }

        InfoRow {
            label: "Frame rate";
            value: root.info.framerate;
        }

        InfoRow {
            label: "Pixel aspect";
            value: root.info.pixel-aspect;
        }

        InfoRow {
            label: "Rotation";
            value: root.info.rotation;
        }

        InfoRow {
            label: "Memory";
            value: root.info.memory;
        }

        Rectangle {
            height: 6px;
        }

        Text {
            text: "Colorimetry";
            color: white;
            font-size: 14px;
            font-weight: 700;
        }

        InfoRow {
            label: "Primaries";
            value: root.info.primaries;
        }

        InfoRow {
            label: "Transfer";
            value: root.info.transfer;
        }

        InfoRow {
            label: "Matrix";
            value: root.info.matrix;
        }

        InfoRow {
            label: "Range";
            value: root.info.range;
        }

        InfoRow {
            label: "DNR";
            value: root.info.hdr;
        }

        Rectangle { }
    }
}

component BitrateCard inherits Rectangle {
    min-width: 240px;
    max-width: 560px;
    background: #1c1c1eee;
    border-width: 1px;
    border-color: #ffffff20;

    VerticalLayout {
        padding: 12px;
        spacing: 5px;

        Text {
            text: "Bitrate";
            color: white;
            font-size: 14px;
            font-weight: 700;
        }

        Rectangle {
            height: 100px;
            background: #00000066;
            clip: true;

            Path {
                width: 100%;
                height: 100%;
                viewbox-x: 0;
                viewbox-y: 0;
                viewbox-width: 300;
                viewbox-height: 100;
                fit: fill;
                commands: InspectorState.video-bitrate-path;
                fill: transparent;
                stroke: #4da3ff;
                stroke-width: 1.5px;
            }

            Path {
                width: 100%;
                height: 100%;
                viewbox-x: 0;
                viewbox-y: 0;
                viewbox-width: 300;
                viewbox-height: 100;
                fit: fill;
                commands: InspectorState.audio-bitrate-path;
                fill: transparent;
                stroke: #6ee7a0;
                stroke-width: 1.5px;
            }

            Text {
                x: 4px;
                y: 2px;
                text: InspectorState.bitrate-peak-label;
                color: #8a8a8a;
                font-size: 10px;
            }
        }

        HorizontalLayout {
            spacing: 12px;

            Text {
                text: InspectorState.video-bitrate-label;
                color: #4da3ff;
                font-size: 12px;
            }

            Text {
                text: InspectorState.audio-bitrate-label;
                color: #6ee7a0;
                font-size: 12px;
            }

            Rectangle { }
        }
    }
}

// Shared chrome for the inspector's data cards.
component Card inherits Rectangle {
    in property <string> title;

    min-width: 240px;
    max-width: 560px;
    background: #1c1c1eee;
    border-width: 1px;
    border-color: #ffffff20;

    VerticalLayout {
        padding: 12px;
        spacing: 5px;

        Text {
            text: root.title;
            color: white;
            font-size: 14px;
            font-weight: 700;
        }

        @children
    }
}

component BufferingCard inherits Card {
    title: "Buffering";

    // Buffer fill meter (0..1, relative to the low/high watermarks).
    Rectangle {
        height: 10px;
        background: #00000066;
        border-radius: 3px;
        clip: true;

        Rectangle {
            x: 0;
            width: parent.width * clamp(InspectorState.buffering-fill, 0.0, 1.0);
            height: parent.height;
            background: #4da3ff;
        }
    }

    InfoRow {
        label: "Fill";
        value: InspectorState.buffering-fill-label;
    }

    if InspectorState.buffering-ahead-label != "": InfoRow {
        label: "Ahead";
        value: InspectorState.buffering-ahead-label;
    }

    InfoRow {
        label: "Mode";
        value: InspectorState.buffering-mode-label;
    }

    if InspectorState.buffering-eta-label != "": InfoRow {
        label: "ETA";
        value: InspectorState.buffering-eta-label;
    }
}

component TracksCard inherits Card {
    title: "Tracks";

    if InspectorState.container != "": InfoRow {
        label: "Container";
        value: InspectorState.container;
    }

    for t in InspectorState.tracks: HorizontalLayout {
        spacing: 6px;

        Text {
            text: t.selected ? "●" : "○";
            color: t.selected ? #6ee7a0 : #666666;
            font-size: 12px;
        }

        Text {
            width: 42px;
            text: t.kind;
            color: #8a8a8a;
            font-size: 12px;
        }

        Text {
            text: t.codec;
            color: white;
            font-size: 12px;
            wrap: word-wrap;
            horizontal-stretch: 1;
        }

        Text {
            text: t.detail;
            color: #b0b0b0;
            font-size: 12px;
        }

        Text {
            text: t.language;
            color: #8a8a8a;
            font-size: 12px;
        }
    }
}

component SourcesCard inherits Card {
    title: "Sources";

    for line in InspectorState.sources-lines: Text {
        text: line;
        color: white;
        font-size: 12px;
        wrap: word-wrap;
    }
}

component SinksCard inherits Card {
    title: "Sinks";

    if Bridge.render-latency-info != "": Text {
        text: Bridge.render-latency-info;
        color: white;
        font-size: 12px;
        wrap: word-wrap;
    }

    for line in InspectorState.sink-lines: Text {
        text: line;
        color: white;
        font-size: 12px;
        wrap: word-wrap;
    }
}

component InternalsCard inherits Card {
    title: "Player internals";

    for line in InspectorState.internals-lines: Text {
        text: line;
        color: white;
        font-size: 12px;
        wrap: word-wrap;
    }
}

component ImageInfoCard inherits Card {
    title: "Image";

    Text {
        text: InspectorState.image-info;
        color: white;
        font-size: 12px;
        wrap: word-wrap;
    }
}

// A viewport onto the laid-out graph: the dark canvas always fills the whole
// available area, and pan/zoom move the graph content within it. Wheel pans,
// ctrl+wheel zooms around the cursor, left-drag pans.
component GraphView inherits Rectangle {
    clip: true;
    // Same chrome as the inspector's data cards.
    background: #1c1c1eee;
    border-width: 1px;
    border-color: #ffffff20;

    property <float> scaling: 1.0;
    property <length> offset-x: 0;
    property <length> offset-y: 0;

    // The hovered wire (via an edge segment or its caps chip), redrawn in
    // the accent color on top of the batched gray wiring.
    property <int> hovered-edge: -1;
    property <string> hover-commands;
    property <string> hover-arrow;

    // The expanded caps chip, rendered as one shared overlay after all the
    // chips so no other chip can draw on top of it. Coordinates are in
    // scene space and scale at render time.
    property <int> expanded-chip: -1;
    property <length> expanded-x;
    property <length> expanded-y;
    property <length> expanded-w;
    property <length> expanded-h;
    property <string> expanded-detail;

    // A fresh dump resets the viewport: fit the whole graph (never zoom
    // past 1:1) and center it, so it can't be stranded off-screen at the
    // previous dump's pan/zoom.
    property <string> graph-stamp: InspectorState.graph.trigger + InspectorState.graph.timestamp;
    changed graph-stamp => {
        root.scaling = Math.clamp(Math.min(
            root.width / Math.max(1px, InspectorState.graph.width),
            root.height / Math.max(1px, InspectorState.graph.height)), 0.1, 1.0);
        root.offset-x = (root.width - InspectorState.graph.width * root.scaling) / 2.0;
        root.offset-y = (root.height - InspectorState.graph.height * root.scaling) / 2.0;
        root.hovered-edge = -1;
        root.expanded-chip = -1;
    }
    init => {
        // Also fit when the view opens onto an already-present graph.
        root.scaling = Math.clamp(Math.min(
            root.width / Math.max(1px, InspectorState.graph.width),
            root.height / Math.max(1px, InspectorState.graph.height)), 0.1, 1.0);
        root.offset-x = (root.width - InspectorState.graph.width * root.scaling) / 2.0;
        root.offset-y = (root.height - InspectorState.graph.height * root.scaling) / 2.0;
    }

    TouchArea {
        scroll-event(event) => {
            if event.modifiers.control {
                let old-scale = root.scaling;
                root.scaling = Math.clamp(root.scaling + (event.delta-y > 0 ? 0.05 : -0.05), 0.1, 5.0);
                // Keep the graph point under the cursor fixed while zooming.
                root.offset-x = self.mouse-x - (self.mouse-x - root.offset-x) * (root.scaling / old-scale);
                root.offset-y = self.mouse-y - (self.mouse-y - root.offset-y) * (root.scaling / old-scale);
            } else {
                root.offset-x += event.delta-x;
                root.offset-y += event.delta-y;
            }
            accept
        }

        // https://github.com/slint-ui/slint/discussions/2235#discussioncomment-4992466
        property <length> drag-start-x;
        property <length> drag-start-y;

        pointer-event(e) => {
            if (e.kind == PointerEventKind.down
                && e.button == PointerEventButton.left) {
                self.drag-start-x = root.offset-x;
                self.drag-start-y = root.offset-y;
            }
        }

        moved => {
            root.offset-x = self.drag-start-x + (self.mouse-x - self.pressed-x);
            root.offset-y = self.drag-start-y + (self.mouse-y - self.pressed-y);
        }
    }

    // Trackpad pinch (and two-finger touch pinch): scale around the gesture
    // center. TouchArea's scroll-event never sees macOS pinch gestures, they
    // arrive as dedicated gesture events that only this handler receives.
    ScaleRotateGestureHandler {
        property <float> start-scale: 1.0;
        property <length> start-offset-x;
        property <length> start-offset-y;

        started => {
            self.start-scale = root.scaling;
            self.start-offset-x = root.offset-x;
            self.start-offset-y = root.offset-y;
        }

        updated => {
            let new-scale = Math.clamp(self.start-scale * self.scale, 0.1, 5.0);
            root.scaling = new-scale;
            // Keep the graph point under the gesture center fixed.
            root.offset-x = self.center.x - (self.center.x - self.start-offset-x) * (new-scale / self.start-scale);
            root.offset-y = self.center.y - (self.center.y - self.start-offset-y) * (new-scale / self.start-scale);
        }
    }

    content := Rectangle {
        x: root.offset-x;
        y: root.offset-y;
        width: InspectorState.graph.width * root.scaling;
        height: InspectorState.graph.height * root.scaling;

        // Boxes first (parents were emitted before their children, so
        // z-order nests correctly), then the wiring, then the labels.
        for r in InspectorState.graph.rects: Rectangle {
            x: r.x * root.scaling;
            y: r.y * root.scaling;
            width: r.width * root.scaling;
            height: r.height * root.scaling;
            background: r.fill;
            border-color: r.stroke;
            border-width: max(1px, 1px * root.scaling);
        }

        // Every edge shares one stroke and every arrowhead one fill, so
        // the whole wiring is two Path items regardless of graph size.
        // The viewbox maps the layout's coordinate space onto the scaled
        // canvas, keeping zoom resolution-free.
        Path {
            width: 100%;
            height: 100%;
            viewbox-x: 0;
            viewbox-y: 0;
            viewbox-width: InspectorState.graph.width / 1px;
            viewbox-height: InspectorState.graph.height / 1px;
            fit: fill;
            commands: InspectorState.graph.edges;
            fill: transparent;
            stroke: #8a8a8a;
            stroke-width: max(1px, 1.2px * root.scaling);
        }

        Path {
            width: 100%;
            height: 100%;
            viewbox-x: 0;
            viewbox-y: 0;
            viewbox-width: InspectorState.graph.width / 1px;
            viewbox-height: InspectorState.graph.height / 1px;
            fit: fill;
            commands: InspectorState.graph.arrows;
            fill: #8a8a8a;
            stroke: transparent;
        }

        // The hovered wire redrawn in the accent color, above the gray batch.
        if root.hovered-edge >= 0: Path {
            width: 100%;
            height: 100%;
            viewbox-x: 0;
            viewbox-y: 0;
            viewbox-width: InspectorState.graph.width / 1px;
            viewbox-height: InspectorState.graph.height / 1px;
            fit: fill;
            commands: root.hover-commands;
            fill: transparent;
            stroke: #4da3ff;
            stroke-width: max(1.5px, 2px * root.scaling);
        }

        if root.hovered-edge >= 0: Path {
            width: 100%;
            height: 100%;
            viewbox-x: 0;
            viewbox-y: 0;
            viewbox-width: InspectorState.graph.width / 1px;
            viewbox-height: InspectorState.graph.height / 1px;
            fit: fill;
            commands: root.hover-arrow;
            fill: #4da3ff;
            stroke: transparent;
        }

        for t in InspectorState.graph.texts: Text {
            x: t.x * root.scaling;
            y: t.y * root.scaling;
            text: t.text;
            color: t.color;
            font-size: t.size * root.scaling;
        }

        // Invisible hover zones along every wire segment.
        for hit in InspectorState.graph.hits: TouchArea {
            x: hit.x * root.scaling;
            y: hit.y * root.scaling;
            width: hit.width * root.scaling;
            height: hit.height * root.scaling;

            changed has-hover => {
                if self.has-hover {
                    root.hovered-edge = hit.edge;
                    root.hover-commands = hit.commands;
                    root.hover-arrow = hit.arrow;
                } else if root.hovered-edge == hit.edge {
                    root.hovered-edge = -1;
                }
            }
        }

        // Caps chips above the wiring. Hovering one expands the chip in
        // place to the full caps block and highlights its wire.
        for l in InspectorState.graph.labels: Rectangle {
            x: l.x * root.scaling;
            y: l.y * root.scaling;
            width: l.width * root.scaling;
            height: l.height * root.scaling;
            background: #1c1c1ef2;
            border-color: root.hovered-edge == l.edge ? #4da3ff : #ffffff20;
            border-width: 1px;
            border-radius: 3px;

            Text {
                x: 6px * root.scaling;
                vertical-alignment: center;
                text: l.summary;
                color: #4da3ff;
                font-size: 10px * root.scaling;
            }

            TouchArea {
                changed has-hover => {
                    // No clearing on exit: the expansion overlay covers the
                    // chip, takes over the hover, and clears when left.
                    if self.has-hover {
                        root.hovered-edge = l.edge;
                        root.hover-commands = l.commands;
                        root.hover-arrow = l.arrow;
                        root.expanded-chip = l.edge;
                        root.expanded-x = l.x;
                        root.expanded-y = l.y;
                        root.expanded-w = max(l.width, l.detail-width);
                        root.expanded-h = l.detail-height;
                        root.expanded-detail = l.detail;
                    }
                }
            }
        }

        // The expanded caps block, over every chip.
        if root.expanded-chip >= 0: Rectangle {
            x: root.expanded-x * root.scaling;
            y: root.expanded-y * root.scaling;
            width: root.expanded-w * root.scaling;
            height: root.expanded-h * root.scaling;
            background: #1c1c1ef8;
            border-color: #4da3ff;
            border-width: 1px;
            border-radius: 3px;
            clip: true;

            Text {
                x: 6px * root.scaling;
                y: 4px * root.scaling;
                text: root.expanded-detail;
                color: #b0b0b0;
                font-size: 10px * root.scaling;
            }

            TouchArea {
                // Which chip this overlay was showing when it got the
                // hover. Leaving only collapses when the state has not
                // already moved to another chip.
                property <int> owner: -1;

                changed has-hover => {
                    if self.has-hover {
                        self.owner = root.expanded-chip;
                    } else if root.expanded-chip == self.owner {
                        root.expanded-chip = -1;
                        root.hovered-edge = -1;
                    }
                }
            }
        }
    }
}

export component Inspector inherits Rectangle {
    background: black.transparentize(15%);

    property <bool> video-playing:
        Bridge.app-state == AppState.Playing
        && Bridge.player-variant == UiPlayerVariant.Video;

    // The component only exists while the inspector is shown, so this samples
    // exactly while it is open.
    Timer {
        interval: 500ms;
        running: true;
        triggered => {
            Bridge.inspector-tick();
        }
    }

    VerticalLayout {
        padding: 12px;
        spacing: 10px;

        HorizontalLayout {
            spacing: 12px;
            alignment: end;

            if InspectorState.have-graph: Text {
                text: "Graph: " + InspectorState.graph.trigger + "@" + InspectorState.graph.timestamp;
                color: #9a9a9a;
                font-size: 12px;
                vertical-alignment: center;
                horizontal-stretch: 1;
            }

            Rectangle {
                horizontal-stretch: 1;
            }

            Button {
                text: InspectorState.dumping
                    ? "Refreshing…"
                    : (InspectorState.have-graph ? "Refresh graph" : "Dump graph");
                enabled: !InspectorState.dumping;
                clicked => {
                    InspectorState.dumping = true;
                    Bridge.refresh-pipeline-graph();
                }
            }

            Button {
                text: "Close";
                clicked => {
                    Bridge.show-inspector = false;
                }
            }
        }

        HorizontalLayout {
            spacing: 10px;

            ScrollView {
                width: 400px;

                VerticalLayout {
                    spacing: 10px;
                    alignment: start;

                    if root.video-playing && Bridge.have-video-dbg-info: VideoInfoCard { }

                    // Only for stream playback: images (and an idle player)
                    // have no flowing bitrate to plot.
                    if InspectorState.have-bitrate
                        && Bridge.app-state == AppState.Playing
                        && (Bridge.player-variant == UiPlayerVariant.Video
                            || Bridge.player-variant == UiPlayerVariant.Audio): BitrateCard { }

                    if InspectorState.have-buffering: BufferingCard { }

                    if InspectorState.sources-lines.length > 0: SourcesCard { }

                    if InspectorState.tracks.length > 0: TracksCard { }

                    if InspectorState.image-info != "": ImageInfoCard { }

                    if Bridge.render-latency-info != "" || InspectorState.sink-lines.length > 0: SinksCard { }

                    if InspectorState.internals-lines.length > 0: InternalsCard { }
                }
            }

            Rectangle {
                horizontal-stretch: 1;

                if InspectorState.have-graph: GraphView {
                    width: 100%;
                    height: 100%;
                }

                if !InspectorState.have-graph: Text {
                    text: InspectorState.dumping ? "Dumping pipeline graph..." : "No graph yet";
                    color: #9a9a9a;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }
    }
}
