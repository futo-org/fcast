#: crates/receiver-core/ui/views/idle.slint:91
msgctxt "IdleView"
msgid "Idle. Ready to cast"
msgstr "Klar til å caste"

#: crates/receiver-core/ui/views/idle.slint:100
msgctxt "IdleView"
msgid ""
"Stream to this device by opening your FCast sender app and selecting this "
"device from the Cast menu, or scan the QR code for instant setup."
msgstr "Strøm til denne enheten ved å åpne en FCast sender applikasjon og "
"velg denne enheten fra Cast menyen, eller scan QR koden for umiddelbar "
"tilkobling."

#: crates/receiver-core/ui/views/idle.slint:120
msgctxt "IdleView"
msgid "Device name"
msgstr "Enhetsnavn"

#: crates/receiver-core/ui/views/idle.slint:133
msgctxt "IdleView"
msgid "Local IP Address"
msgstr "Lokal IP adresse"

#: crates/receiver-core/ui/views/idle.slint:141
msgctxt "IdleView"
msgid "An update is available. Do you want to update now?"
msgstr "En oppdatering er tilgjengelig. Ønsker du å oppdatere nå?"

#: crates/receiver-core/ui/views/idle.slint:149
#: crates/receiver-core/ui/views/idle.slint:149
msgctxt "IdleView"
msgid "Yes"
msgstr "Ja"

#: crates/receiver-core/ui/views/idle.slint:155
#: crates/receiver-core/ui/views/idle.slint:155
msgctxt "IdleView"
msgid "No"
msgstr "Nei"

#: crates/receiver-core/ui/views/idle.slint:166
msgctxt "IdleView"
msgid "Downloading update..."
msgstr "Laster ned oppdatering..."

#: crates/receiver-core/ui/views/idle.slint:177
msgctxt "IdleView"
msgid "Failed to download update: {}"
msgstr "Klarte ikke å laste ned oppdatering: {}"

#: crates/receiver-core/ui/views/idle.slint:183
msgctxt "IdleView"
msgid "Failed to install update: {}"
msgstr "Klarte ikke å installere oppdatering: {}"

#: crates/receiver-core/ui/views/idle.slint:189
msgctxt "IdleView"
msgid "Installed update successfully. Do you want to restart the app now?"
msgstr "Oppdatering installert. Ønsker du å restarte applikasjonen nå?"

#: crates/receiver-core/ui/views/idle.slint:248
msgctxt "IdleView"
msgid ""
"Your device isn’t connected to a network. Connect to network via LAN or "
"Wifi to continue."
msgstr "Enheten din er ikke tilkoblet ett nettverk. Koble til ett nettverk "
"via LAN eller WiFi for å fortsette"

