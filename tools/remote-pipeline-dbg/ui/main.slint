import { ScrollView, TabWidget, Palette, LineEdit, Button, HorizontalBox, VerticalBox } from "std-widgets.slint";
import { Icons } from "../../../ui-components/std-widgets.slint";

export enum WaitingState {
    Waiting,
    Receiving,
    Decoding,
}

// A batch of geometry sharing one fill/stroke, as an SVG path string.
export struct UiGraphPath {
    commands: string,
    fill: brush,
    stroke: brush,
    stroke-width: length,
}

// A single text label anchored at (x, y) in the graph's coordinate space.
// `align`: 0 = left, 1 = center, 2 = right — the anchor is offset by the
// label's own rendered width so it never gets clipped to a fixed box.
export struct UiGraphText {
    x: length,
    y: length,
    size: length,
    text: string,
    color: color,
    align: int,
}

export struct UiGraphDump {
    title: string,
    client: string,
    pipeline: string,
    trigger: string,
    // Graph bounds (graphviz layout, in points treated as pixels).
    width: length,
    height: length,
    paths: [UiGraphPath],
    texts: [UiGraphText],
}

export global Bridge {
    in property <WaitingState> waiting-state: WaitingState.Waiting;
    in property <[UiGraphDump]> dumps;
    in-out property <int> selected-dump: -1;

    pure callback remove-element(dumps: [UiGraphDump], idx: int);
    callback dump-remote(addr: string);
}

component TabEntry inherits Rectangle {
    in property <string> title <=> txt.text;
    in property <bool> selected;

    background: ta.has-hover
        ? (selected ? Palette.selection-background.transparentize(50%) : Palette.background)
        : selected ? Palette.selection-background : Palette.alternate-background;
    width: hl.preferred-width + 10px;

    callback select();
    callback close();

    ta := TouchArea {
        clicked => select();

        mouse-cursor: pointer;
    }

    hl := HorizontalLayout {
        HorizontalLayout {
            padding: 5px;

            txt := Text {
                vertical-alignment: center;
            }

            if title != "Start": Rectangle {
                background: close-ta.has-hover ? red : transparent;

                close-ta := TouchArea {
                    mouse-cursor: pointer;

                    clicked => close();
                }

                Image {
                    source: Icons.close;
                    colorize: Palette.foreground;
                }
            }
        }

        Rectangle {
            width: 2px;
            background: Palette.foreground.transparentize(80%);
        }
    }
}

export component MainWindow inherits Window {
    title: "Remote pipeline debugger";

    preferred-width: 800px;
    preferred-height: 500px;

    // Zoom factor applied to the graph canvas (1.0 == 100%).
    property <float> scaling: 1.0;

    VerticalLayout {
        ScrollView {
            height: 35px;

            HorizontalLayout {
                TabEntry {
                    title: "Start";
                    selected: Bridge.selected-dump == -1;

                    select => {
                        Bridge.selected-dump = -1;
                    }
                }

                for dump[idx] in Bridge.dumps: TabEntry {
                    title: dump.title;
                    selected: Bridge.selected-dump == idx;

                    select => {
                        Bridge.selected-dump = idx;
                    }

                    close => {
                        Bridge.remove-element(Bridge.dumps, idx);
                        if Bridge.selected-dump == idx {
                            Bridge.selected-dump = idx - 1;
                        } else if Bridge.selected-dump > idx {
                            Bridge.selected-dump -= 1;
                        }
                    }
                }
            }
        }

        if Bridge.selected-dump == -1: VerticalBox {
            alignment: center;

            HorizontalBox {
                alignment: center;

                remote-addr := LineEdit {
                    text: "127.0.0.1:46897";
                }

                Button {
                    text: "Dump";
                    clicked => Bridge.dump-remote(remote-addr.text);
                }
            }

            Text {
                horizontal-alignment: center;

                states [
                    waiting when Bridge.waiting-state == WaitingState.Waiting: {
                        text: "Waiting for a client to connect...";
                    }
                    receiving when Bridge.waiting-state == WaitingState.Receiving: {
                        text: "Receiving data from client...";
                    }
                    decoding when Bridge.waiting-state == WaitingState.Decoding: {
                        text: "Decoding data from client...";
                    }
                ]

            }
        }

        if Bridge.selected-dump >= 0: VerticalLayout {
            HorizontalLayout {
                alignment: center;

                padding: 5px;
                spacing: 10px;

                Text {
                    text: "Client: " + Bridge.dumps[Bridge.selected-dump].client;
                }

                Text {
                    text: "Pipeline: " + Bridge.dumps[Bridge.selected-dump].pipeline;
                }

                Text {
                    text: "Trigger: " + Bridge.dumps[Bridge.selected-dump].trigger;
                }
            }

            property <UiGraphDump> dump: Bridge.dumps[Bridge.selected-dump];
            property <float> start-scaling: 1.0;

            // Trackpad pinch-to-zoom (macOS/iOS) and touchscreen gestures.
            // Mouse-wheel ctrl+scroll zoom is handled by the TouchArea below.
            ScaleRotateGestureHandler {
                started => {
                    start-scaling = scaling;
                }
                updated => {
                    let old-scale = scaling;
                    scaling = start-scaling * self.scale;
                    // Keep the pinch centre fixed on screen, matching the
                    // ctrl+scroll focal-point behaviour.
                    scroll.viewport-x = (self.center.x + scroll.viewport-x) - (self.center.x * (scaling / old-scale));
                    scroll.viewport-y = (self.center.y + scroll.viewport-y) - (self.center.y * (scaling / old-scale));
                }

            scroll := ScrollView {
                viewport-width: canvas.width * scaling;
                viewport-height: canvas.height * scaling;

                TouchArea {
                    scroll-event(event) => {
                        if !event.modifiers.control {
                            return reject;
                        }

                        let old-scale = scaling;
                        scaling += event.delta-y > 0 ? 0.05 : -0.05;
                        scroll.viewport-x = (self.mouse-x + scroll.viewport-x) - (self.mouse-x * (scaling / old-scale));
                        scroll.viewport-y = (self.mouse-y + scroll.viewport-y) - (self.mouse-y * (scaling / old-scale));

                        accept
                    }

                    // https://github.com/slint-ui/slint/discussions/2235#discussioncomment-4992466
                    property<length> drag-start-x;
                    property<length> drag-start-y;

                    pointer-event(e) => {
                        if (e.kind == PointerEventKind.down
                            && e.button == PointerEventButton.left) {
                            self.drag-start-x = scroll.viewport-x;
                            self.drag-start-y = scroll.viewport-y;
                        }
                    }

                    moved => {
                        scroll.viewport-x += (self.mouse-x - self.pressed-x);
                        scroll.viewport-y += (self.mouse-y - self.pressed-y);
                    }
                }

                canvas := Rectangle {
                    width: dump.width;
                    height: dump.height;
                    transform-scale: scaling;
                    // Graphviz assumes a white page; keep it readable regardless
                    // of the app theme.
                    background: white;

                    for p in dump.paths: Path {
                        x: 0;
                        y: 0;
                        width: parent.width;
                        height: parent.height;
                        // Map the graph's coordinate space 1:1 onto the canvas so
                        // every path shares one absolute coordinate system.
                        viewbox-x: 0;
                        viewbox-y: 0;
                        viewbox-width: dump.width / 1px;
                        viewbox-height: dump.height / 1px;
                        fit: fill;

                        commands: p.commands;
                        fill: p.fill;
                        stroke: p.stroke;
                        stroke-width: p.stroke-width;
                    }

                    for t in dump.texts: Text {
                        // Offset the anchor by the label's own width so text is
                        // left/center/right aligned without a clipping box.
                        x: t.align == 0
                            ? t.x
                            : t.align == 2
                                ? t.x - self.width
                                : t.x - self.width / 2;
                        y: t.y;
                        text: t.text;
                        color: t.color;
                        font-size: t.size;
                    }
                }
            }
            }
        }
    }
}
